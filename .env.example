# PostgreSQL connection string used by Prisma.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/studymind?schema=public"

# Generate a strong value before using auth outside local development.
NEXTAUTH_SECRET="replace-with-a-long-random-secret"

# Match the URL and port used by your local or deployed app.
NEXTAUTH_URL="http://127.0.0.1:3000"
